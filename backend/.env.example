# Database Configuration
DATABASE_URL=
DB_HOST=localhost
DB_NAME=postgres
DB_USER=
DB_PASSWORD=
DB_PORT=5432

# Session Configuration
SESSION_SECRET=your-secret-key-minimum-16-characters
COOKIE_NAME=tailor.sid
COOKIE_SECURE=false

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Environment
NODE_ENV=development
PORT=4000

# Password Hashing
BCRYPT_SALT_ROUNDS=10

# Backup Directory
BACKUP_DIRECTORY=./backups

# Redis Configuration (Optional - recommended for Vercel/serverless sessions)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
